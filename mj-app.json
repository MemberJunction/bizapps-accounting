{
  "$schema": "https://schema.memberjunction.org/mj-app/v1.json",
  "manifestVersion": 1,
  "name": "mj-bizapps-accounting",
  "displayName": "BizApps Accounting",
  "description": "AR subsidiary ledger of record and journal entry primitives (GL accounts, accounting periods, balanced JEs with multi-currency, dimensions, tax) for MemberJunction. Not a general ledger — batches to ERP/QBO/NetSuite/BC.",
  "version": "0.1.0",
  "license": "ISC",
  "icon": "fa-solid fa-file-invoice-dollar",
  "publisher": {
    "name": "MemberJunction",
    "url": "https://memberjunction.com"
  },
  "repository": "https://github.com/MemberJunction/bizapps-accounting",
  "mjVersionRange": ">=5.38.0 <6.0.0",
  "dependencies": {
    "mj-bizapps-common": {
      "version": ">=1.0.0 <2.0.0",
      "repository": "https://github.com/MemberJunction/bizapps-common"
    },
    "mj-bizapps-tasks": {
      "version": ">=1.0.0 <2.0.0",
      "repository": "https://github.com/MemberJunction/bizapps-tasks"
    }
  },
  "schema": {
    "name": "__mj_BizAppsAccounting",
    "createIfNotExists": true
  },
  "migrations": {
    "directory": "migrations",
    "engine": "skyway"
  },
  "metadata": {
    "directory": "metadata"
  },
  "packages": {
    "server": [
      {
        "name": "@mj-biz-apps/accounting-server",
        "role": "bootstrap",
        "startupExport": "LoadBizAppsAccountingServer"
      }
    ],
    "client": [
      {
        "name": "@mj-biz-apps/accounting-ng",
        "role": "bootstrap",
        "startupExport": "LoadBizAppsAccountingClient"
      }
    ],
    "shared": [
      {
        "name": "@mj-biz-apps/accounting-entities",
        "role": "library"
      },
      {
        "name": "@mj-biz-apps/accounting-actions",
        "role": "library"
      }
    ]
  },
  "code": {
    "visibility": "public",
    "sourceDirectory": "packages"
  },
  "categories": [
    "Business",
    "Accounting",
    "Finance"
  ],
  "tags": [
    "accounting",
    "journal-entry",
    "general-ledger",
    "accounts-receivable",
    "deferred-revenue",
    "multi-currency",
    "sales-tax",
    "subledger"
  ]
}
